# AI4CEO Portal — copy to .env.local and fill in
# Supabase (client-exposed)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only. SERVICE ROLE is NOT provided in the root .env.
# Some admin operations (bypassing RLS) need it — leave as TODO until available.
SUPABASE_SERVICE_ROLE_KEY=TODO_SERVICE_ROLE_KEY

# AI 조교 (Claude)
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-5

# Email (nodemailer SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SENDER=you@example.com
EMAIL_PASSWORD=your_gmail_app_password

# Tax invoice provider: manual (default) | popbill (mock mode)
TAX_INVOICE_PROVIDER=manual

# Toss Payments 결제창 (PRD v3.2 C-8) — API 개별 연동 키만(결제위젯 제외).
# 테스트 키(test_ck/test_sk)로 구현·검증. Go-live 시 live 키로 교체 + PAYMENT_TOSS_ENABLED=on.
PAYMENT_TOSS_ENABLED=off
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...
