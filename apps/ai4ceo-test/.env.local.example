# === AI4CEO 테스트 하네스 필요 환경변수 (문서용 예시) ===
# apps/ai4ceo-test/.env.local 로 복사한 뒤 실제 값을 채운다. 실제 키는 절대 커밋하지 않는다.

# E2E 대상 base URL. 미지정 시 프로덕션(https://ai4ceo-portal.vercel.app) 기본값 사용.
TEST_BASE_URL=https://ai4ceo-portal.vercel.app

# Supabase (프로덕션 재사용, project ref: olofwxsavfthsmmwjwzk)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
SUPABASE_SERVICE_ROLE_KEY=<service role key — provision/시드/티어다운 전용, 서버에서만>

# AI (rag.smoke.spec 에서 /api/ai/tutor 스트림 검증용 — 앱 라우트가 사용)
OPENAI_API_KEY=<openai key>
ANTHROPIC_API_KEY=<anthropic key>
AI_MODEL=claude-fable-5

# 테스트 계정 공통 비밀번호 (5개 계정 모두 동일)
TEST_ACCOUNT_PASSWORD=uscdon00

# QA 대시보드 basic-auth (middleware.ts) — 기본값 admin / uscdon00
QA_DASHBOARD_USER=admin
QA_DASHBOARD_PASSWORD=uscdon00
